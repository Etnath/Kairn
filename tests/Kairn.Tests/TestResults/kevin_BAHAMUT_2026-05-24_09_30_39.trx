SELECT "i"."Id", "i"."CreatedAt", "i"."Currency", "i"."CustomerId", "i"."Date", "i"."DueDate", "i"."IsCreditNote", "i"."JournalEntryId", "i"."Notes", "i"."OriginalInvoiceId", "i"."Reference", "i"."RevenueAccountId", "i"."RowVersion", "i"."Status", "i"."TenantId", "i"."UpdatedAt", "i0"."Id", "i0"."Description", "i0"."DiscountPct", "i0"."InvoiceId", "i0"."Quantity", "i0"."SortOrder", "i0"."TaxRate", "i0"."TaxRateId", "i0"."UnitPrice", "i1"."Id", "i1"."Amount", "i1"."CreatedAt", "i1"."Date", "i1"."InvoiceId", "i1"."JournalEntryId", "i1"."Method", "i1"."Reference", "i1"."RowVersion", "i1"."TenantId", "i1"."UpdatedAt", "s"."Id", "s"."CreatedAt", "s"."Currency", "s"."CustomerId", "s"."Date", "s"."DueDate", "s"."IsCreditNote", "s"."JournalEntryId", "s"."Notes", "s"."OriginalInvoiceId", "s"."Reference", "s"."RevenueAccountId", "s"."RowVersion", "s"."Status", "s"."TenantId", "s"."UpdatedAt", "s"."Id0", "s"."Description", "s"."DiscountPct", "s"."InvoiceId", "s"."Quantity", "s"."SortOrder", "s"."TaxRate", "s"."TaxRateId", "s"."UnitPrice"&#xD;
FROM "Invoices" AS "i"&#xD;
LEFT JOIN "InvoiceLines" AS "i0" ON "i"."Id" = "i0"."InvoiceId"&#xD;
LEFT JOIN "InvoicePayments" AS "i1" ON "i"."Id" = "i1"."InvoiceId"&#xD;
LEFT JOIN (&#xD;
    SELECT "i2"."Id", "i2"."CreatedAt", "i2"."Currency", "i2"."CustomerId", "i2"."Date", "i2"."DueDate", "i2"."IsCreditNote", "i2"."JournalEntryId", "i2"."Notes", "i2"."OriginalInvoiceId", "i2"."Reference", "i2"."RevenueAccountId", "i2"."RowVersion", "i2"."Status", "i2"."TenantId", "i2"."UpdatedAt", "i3"."Id" AS "Id0", "i3"."Description", "i3"."DiscountPct", "i3"."InvoiceId", "i3"."Quantity", "i3"."SortOrder", "i3"."TaxRate", "i3"."TaxRateId", "i3"."UnitPrice"&#xD;
    FROM "Invoices" AS "i2"&#xD;
    LEFT JOIN "InvoiceLines" AS "i3" ON "i2"."Id" = "i3"."InvoiceId"&#xD;
) AS "s" ON "i"."Id" = "s"."OriginalInvoiceId"&#xD;
WHERE "i"."TenantId" = @tenantId AND NOT ("i"."IsCreditNote") AND "i"."Status" = 'Overdue'&#xD;
