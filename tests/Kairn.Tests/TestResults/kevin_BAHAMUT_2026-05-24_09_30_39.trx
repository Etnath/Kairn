    ORDER BY "j"."Date" DESC, "j"."Reference" DESC&#xD;
    LIMIT @p2 OFFSET @p&#xD;
) AS "j1"&#xD;
LEFT JOIN (&#xD;
    SELECT "j0"."Id", "j0"."AccountId", "j0"."Credit", "j0"."Currency", "j0"."Debit", "j0"."EntryId", "j0"."ExchangeRate", "j0"."IsReconciled", "j0"."Memo", "j0"."SystemRate", "a"."Id" AS "Id0", "a"."Code", "a"."CreatedAt", "a"."Currency" AS "Currency0", "a"."IsActive", "a"."IsCurrent", "a"."Name", "a"."ParentId", "a"."RowVersion", "a"."TenantId", "a"."Type", "a"."UpdatedAt"&#xD;
    FROM "JournalLines" AS "j0"&#xD;
    INNER JOIN "Accounts" AS "a" ON "j0"."AccountId" = "a"."Id"&#xD;
) AS "s" ON "j1"."Id" = "s"."EntryId"&#xD;
ORDER BY "j1"."Date" DESC, "j1"."Reference" DESC, "j1"."Id", "s"."Id"&#xD;
