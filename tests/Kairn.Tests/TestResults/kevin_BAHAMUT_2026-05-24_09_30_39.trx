LEFT JOIN (&#xD;
    SELECT "i2"."Id", "i2"."CreatedAt", "i2"."Currency", "i2"."CustomerId", "i2"."Date", "i2"."DueDate", "i2"."IsCreditNote", "i2"."JournalEntryId", "i2"."Notes", "i2"."OriginalInvoiceId", "i2"."Reference", "i2"."RevenueAccountId", "i2"."RowVersion", "i2"."Status", "i2"."TenantId", "i2"."UpdatedAt", "i3"."Id" AS "Id0", "i3"."Description", "i3"."DiscountPct", "i3"."InvoiceId", "i3"."Quantity", "i3"."SortOrder", "i3"."TaxRate", "i3"."TaxRateId", "i3"."UnitPrice"&#xD;
