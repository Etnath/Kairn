@using Kairn.Domain.Entities
@inject IStringLocalizer<BillStatusChip> L

<span style="display:inline-flex;align-items:center;padding:2px 10px;border-radius:9999px;
             font-size:0.75rem;font-weight:500;line-height:1.6;white-space:nowrap;
             background-color:@_bg;color:@_fg">
    @_label
</span>

@code {
    [Parameter, EditorRequired] public BillStatus Status { get; set; }

    private string _bg => Status switch
    {
        BillStatus.Draft            => "#D6D3CA",
        BillStatus.PendingApproval  => "#FBF2E0",
        BillStatus.Approved         => "#EAF0F6",
        BillStatus.PartiallyPaid    => "#FBF2E0",
        BillStatus.Paid             => "#E8F4ED",
        BillStatus.Overdue          => "#FAECE8",
        BillStatus.Void             => "#D6D3CA",
        BillStatus.Rejected         => "#FAECE8",
        _                           => "#D6D3CA",
    };

    private string _fg => Status switch
    {
        BillStatus.Draft            => "#4A4843",
        BillStatus.PendingApproval  => "#8F6008",
        BillStatus.Approved         => "#2A4F6E",
        BillStatus.PartiallyPaid    => "#8F6008",
        BillStatus.Paid             => "#1F6040",
        BillStatus.Overdue          => "#7E2A14",
        BillStatus.Void             => "#8C8980",
        BillStatus.Rejected         => "#7E2A14",
        _                           => "#4A4843",
    };

    private string _label => Status switch
    {
        BillStatus.Draft            => L["Draft"],
        BillStatus.PendingApproval  => L["PendingApproval"],
        BillStatus.Approved         => L["Approved"],
        BillStatus.PartiallyPaid    => L["PartiallyPaid"],
        BillStatus.Paid             => L["Paid"],
        BillStatus.Overdue          => L["Overdue"],
        BillStatus.Void             => L["Void"],
        BillStatus.Rejected         => L["Rejected"],
        _                           => Status.ToString(),
    };
}
