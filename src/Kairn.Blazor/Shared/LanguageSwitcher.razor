@inject NavigationManager Navigation
@inject IJSRuntime JS

@{
    var isFr = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "fr";
    var nextCulture = isFr ? "en" : "fr-FR";
    var label = isFr ? "FR" : "EN";
}

<MudButton Variant="Variant.Text" Color="Color.Inherit" Size="Size.Small"
           OnClick="@(() => SwitchLanguage(nextCulture))">
    @label
</MudButton>

@code {
    private async Task SwitchLanguage(string culture)
    {
        // kairn.switchCulture sets the cookie and then assigns window.location.href
        // directly, bypassing Blazor's enhanced-navigation pipeline so that the
        // full page (including <head> assets) is re-fetched with the new culture.
        await JS.InvokeVoidAsync("kairn.switchCulture", culture, Navigation.Uri);
    }
}
