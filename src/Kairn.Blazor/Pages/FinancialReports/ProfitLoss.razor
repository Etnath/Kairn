                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">@L["Col_Variance"]</span>
                <span style="min-width:72px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">@L["Col_VarPct"]</span>
