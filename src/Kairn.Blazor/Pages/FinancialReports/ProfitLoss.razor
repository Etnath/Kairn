        }
    }
}

@code {
    private DateTime? _from         = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _to           = DateTime.Today;
    private bool      _hideZero     = true;
    private bool      _loading;
    private PnlReport?           _report;
    private string?              _activePreset = "Preset_ThisMonth";

    private bool                 _compEnabled;
    private DateTime?            _compFrom;
    private DateTime?            _compTo;
    private string?              _compActivePreset;
    private PnlComparisonReport? _compReport;

    private bool             _budgetEnabled;
    private PnlBudgetReport? _budgetReport;
    private bool             _noBudget;

    protected override async Task OnInitializedAsync()
    {
        var qs = QueryHelpers.ParseQuery(Nav.ToAbsoluteUri(Nav.Uri).Query);
        if (qs.TryGetValue("from", out var fromSv) && DateOnly.TryParse(fromSv, out var fromDate))
        {
            _from = fromDate.ToDateTime(TimeOnly.MinValue);
            _activePreset = null;
        }
        if (qs.TryGetValue("to", out var toSv) && DateOnly.TryParse(toSv, out var toDate))
        {
            _to = toDate.ToDateTime(TimeOnly.MinValue);
            _activePreset = null;
        }
        await GenerateAsync();
    }

    // ── Primary period helpers ───────────────────────────────────────────

    private Variant PresetVariant(string key) =>
        _activePreset == key ? Variant.Filled : Variant.Outlined;

    private void ApplyPreset(string key)
    {
        var today = DateTime.Today;
        (_from, _to) = key switch
        {
            "Preset_ThisMonth"   => (new DateTime(today.Year, today.Month, 1), today),
            "Preset_LastMonth"   => (new DateTime(today.AddMonths(-1).Year, today.AddMonths(-1).Month, 1),
                                     new DateTime(today.AddMonths(-1).Year, today.AddMonths(-1).Month,
                                         DateTime.DaysInMonth(today.AddMonths(-1).Year, today.AddMonths(-1).Month))),
            "Preset_ThisQuarter" => (new DateTime(today.Year, ((today.Month - 1) / 3) * 3 + 1, 1), today),
            "Preset_Ytd"         => (new DateTime(today.Year, 1, 1), today),
            "Preset_LastYear"    => (new DateTime(today.Year - 1, 1, 1), new DateTime(today.Year - 1, 12, 31)),
            _                    => (_from, _to),
        };
        _activePreset = key;
        RecomputeCompIfPreset();
    }

    private void OnFromChanged(DateTime? d)
    {
        _from = d;
        _activePreset = null;
        RecomputeCompIfPreset();
    }

    private void OnToChanged(DateTime? d)
    {
        _to = d;
        _activePreset = null;
        RecomputeCompIfPreset();
    }

    // ── Comparison period helpers ────────────────────────────────────────

    private Variant CompPresetVariant(string? key) =>
        _compActivePreset == key ? Variant.Filled : Variant.Outlined;

    private void ApplyCompPreset(string key)
    {
        if (_from is null || _to is null) return;
        (_compFrom, _compTo) = key switch
        {
            "CompPreset_PriorMonth"   => (_from.Value.AddMonths(-1), _to.Value.AddMonths(-1)),
            "CompPreset_PriorQuarter" => (_from.Value.AddMonths(-3), _to.Value.AddMonths(-3)),
            "CompPreset_PriorYear"    => (_from.Value.AddYears(-1),  _to.Value.AddYears(-1)),
            _                         => (_compFrom, _compTo),
        };
        _compActivePreset = key;
    }

    private void RecomputeCompIfPreset()
    {
        if (_compEnabled && _compActivePreset is not null and not "CompPreset_Custom")
            ApplyCompPreset(_compActivePreset);
    }

    private void OnCompEnabledChanged(bool value)
    {
        _compEnabled = value;
        if (value)
        {
            if (_compFrom is null || _compTo is null)
                ApplyCompPreset("CompPreset_PriorYear");
            _budgetEnabled = false;
            _budgetReport  = null;
            _noBudget      = false;
        }
        else
        {
            _compReport = null;
        }
    }

    private void OnBudgetEnabledChanged(bool value)
    {
        _budgetEnabled = value;
        if (value)
        {
            _compEnabled = false;
            _compReport  = null;
        }
        else
        {
            _budgetReport = null;
            _noBudget     = false;
        }
    }

    // ── Generate & export ────────────────────────────────────────────────

    private async Task GenerateAsync()
    {
        if (_from is null || _to is null) return;
        _loading = true;
        try
        {
            var primary = await PnlService.GenerateAsync(new PnlQuery(
                CurrentUser.TenantId,
                DateOnly.FromDateTime(_from.Value),
                DateOnly.FromDateTime(_to.Value),
                _hideZero));

            _report       = primary;
            _compReport   = null;
            _budgetReport = null;
            _noBudget     = false;

            if (_compEnabled && _compFrom is not null && _compTo is not null)
            {
                var comparison = await PnlService.GenerateAsync(new PnlQuery(
                    CurrentUser.TenantId,
                    DateOnly.FromDateTime(_compFrom.Value),
                    DateOnly.FromDateTime(_compTo.Value),
                    _hideZero));

                _compReport = new PnlComparisonReport(primary, comparison);
            }

            if (_budgetEnabled)
            {
                _budgetReport = await PnlService.GetBudgetOverlayAsync(primary, CurrentUser.TenantId,
                    DateOnly.FromDateTime(_from.Value), DateOnly.FromDateTime(_to.Value));
                _noBudget = _budgetReport is null;
            }
        }
        finally { _loading = false; }
    }

    private async Task ExportPdfAsync()
    {
        if (_report is null) return;
        _loading = true;
        try
        {
            var meta = PnlExportMeta.Now(CurrentUser.UserName);
            byte[] bytes;
            string filename;
            if (_budgetReport is not null)
            {
                bytes    = PnlExporter.ToPdf(_budgetReport, meta);
                filename = $"PL_{_report.From:yyyy-MM}_{_report.To:yyyy-MM}_budget.pdf";
            }
            else if (_compReport is not null)
            {
                bytes    = PnlExporter.ToPdf(_compReport, meta);
                filename = $"PL_{_compReport.Current.From:yyyy-MM}_{_compReport.Current.To:yyyy-MM}_vs_{_compReport.Comparison.From:yyyy-MM}_{_compReport.Comparison.To:yyyy-MM}.pdf";
            }
            else
            {
                bytes    = PnlExporter.ToPdf(_report, meta);
                filename = $"PL_{_report.From:yyyy-MM}_{_report.To:yyyy-MM}.pdf";
            }
            await JS.InvokeVoidAsync("kairn.downloadFile", filename, "application/pdf", bytes);
        }
        finally { _loading = false; }
    }

    private async Task ExportCsvAsync()
    {
        if (_report is null) return;
        _loading = true;
        try
        {
            var meta = PnlExportMeta.Now(CurrentUser.UserName);
            string csv;
            string filename;
            if (_budgetReport is not null)
            {
                csv      = PnlExporter.ToCsv(_budgetReport, meta);
                filename = $"PL_{_report.From:yyyy-MM}_{_report.To:yyyy-MM}_budget.csv";
            }
            else if (_compReport is not null)
            {
                csv      = PnlExporter.ToCsv(_compReport, meta);
                filename = $"PL_{_compReport.Current.From:yyyy-MM}_{_compReport.Current.To:yyyy-MM}_vs_{_compReport.Comparison.From:yyyy-MM}_{_compReport.Comparison.To:yyyy-MM}.csv";
            }
            else
            {
                csv      = PnlExporter.ToCsv(_report, meta);
                filename = $"PL_{_report.From:yyyy-MM}_{_report.To:yyyy-MM}.csv";
            }
            await JS.InvokeVoidAsync("kairn.downloadFile", filename, "text/csv",
                System.Text.Encoding.UTF8.GetBytes(csv));
        }
        finally { _loading = false; }
    }

    // ── Drill-down ───────────────────────────────────────────────────────

    private Task OpenLineAsync(PnlAccountLine line) =>
        OpenDrillDownAsync(line.AccountId, line.AccountCode, line.AccountName, line.Group,
            _report!.From, _report.To);

    private Task OpenCompLineAsync(PnlComparisonLine line) =>
        OpenDrillDownAsync(line.AccountId, line.AccountCode, line.AccountName, line.Group,
            _compReport!.Current.From, _compReport.Current.To);

    private Task OpenBudgetLineAsync(PnlBudgetLine line) =>
        OpenDrillDownAsync(line.AccountId, line.AccountCode, line.AccountName, line.Group,
            _report!.From, _report.To);

    private async Task OpenDrillDownAsync(
        Guid accountId, string code, string name, PnlGroup group, DateOnly from, DateOnly to)
    {
        var parameters = new DialogParameters<PnlDrillDownDialog>
        {
            { d => d.AccountId,   accountId },
            { d => d.AccountCode, code },
            { d => d.AccountName, name },
            { d => d.IsRevenue,   group == PnlGroup.Revenue },
            { d => d.From,        from },
            { d => d.To,          to },
            { d => d.TenantId,    CurrentUser.TenantId },
        };

        await DialogService.ShowAsync<PnlDrillDownDialog>(
            string.Empty, parameters,
            new DialogOptions
            {
                MaxWidth         = MaxWidth.Large,
                FullWidth        = true,
                CloseButton      = true,
                CloseOnEscapeKey = true,
            });
    }

    // ── Colour helpers ───────────────────────────────────────────────────

    private static string SignedColour(decimal value) =>
        value > 0 ? "#1F6040" : value < 0 ? "#7E2A14" : "#8C8980";

    private static string SummaryVarColour(decimal variance) =>
        variance > 0 ? "#1F6040" : variance < 0 ? "#7E2A14" : "#8C8980";

    private static string VarColour(decimal variance, PnlGroup group)
    {
        if (variance == 0m) return "#8C8980";
        bool favorable = group == PnlGroup.Revenue ? variance > 0 : variance < 0;
        return favorable ? "#1F6040" : "#7E2A14";
    }

    private static string FormatVarPct(decimal? pct) =>
        pct.HasValue ? $"{pct.Value:+0.0;-0.0;0.0}%" : "N/A";

    private static decimal? VarPct(decimal current, decimal comparison) =>
        comparison == 0m ? null : Math.Round((current - comparison) / Math.Abs(comparison) * 100m, 1);
}
