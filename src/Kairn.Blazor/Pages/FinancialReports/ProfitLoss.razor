                        @_report.Ebitda.ToString("N2")
                    </MudText>
                </MudStack>
            </MudPaper>

            @* ── Interest ── *@
            var interestLines = _report.Lines.Where(l => l.Group == PnlGroup.Interest).ToList();
            @if (interestLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">
                        @L["Group_Interest"]
                    </MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in interestLines)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Style="padding:3px 0;border-bottom:1px solid #F0F0F0" Class="pnl-line-clickable" @onclick="@(() => OpenLineAsync(line))">
                            <MudText Typo="Typo.body2" Style="min-width:80px;color:#999">@line.AccountCode</MudText>
                            <MudText Typo="Typo.body2" Style="flex:1" Class="pnl-acct-name">@line.AccountName</MudText>
                            <MudText Typo="Typo.body2" Style="min-width:130px;text-align:right;font-variant-numeric:tabular-nums">
                                @line.Amount.ToString("N2")
                            </MudText>
                        </MudStack>
                    }
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-1" Style="padding:4px 0;border-top:1px solid #CCC">
                        <MudText Typo="Typo.body2" Style="flex:1;font-weight:600">@L["Sub_Interest"]</MudText>
                        <MudText Typo="Typo.body2" Style="min-width:130px;text-align:right;font-variant-numeric:tabular-nums;font-weight:600">
                            @_report.TotalInterest.ToString("N2")
                        </MudText>
                    </MudStack>
                </div>
            }

            @* ── Tax ── *@
            var taxLines = _report.Lines.Where(l => l.Group == PnlGroup.Tax).ToList();
            @if (taxLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">
                        @L["Group_Tax"]
                    </MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in taxLines)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Style="padding:3px 0;border-bottom:1px solid #F0F0F0" Class="pnl-line-clickable" @onclick="@(() => OpenLineAsync(line))">
                            <MudText Typo="Typo.body2" Style="min-width:80px;color:#999">@line.AccountCode</MudText>
                            <MudText Typo="Typo.body2" Style="flex:1" Class="pnl-acct-name">@line.AccountName</MudText>
                            <MudText Typo="Typo.body2" Style="min-width:130px;text-align:right;font-variant-numeric:tabular-nums">
