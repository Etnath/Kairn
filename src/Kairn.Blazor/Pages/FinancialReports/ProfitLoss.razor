@page "/reports/profit-loss"
@attribute [Authorize]
@using System.Globalization
@using Microsoft.AspNetCore.WebUtilities
@inject IStringLocalizer<ProfitLoss> L
@inject IPnlService PnlService
@inject IPnlExporter PnlExporter
@inject IJSRuntime JS
@inject ICurrentUserContext CurrentUser
@inject IDialogService DialogService
@inject NavigationManager Nav

<style>
    .pnl-line-clickable { cursor: pointer; }
    .pnl-line-clickable:hover { background-color: rgba(0,0,0,0.04); }
    .pnl-line-clickable:hover .pnl-acct-name { text-decoration: underline; }
</style>

<PageTitle>@L["Title"] – Kairn</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Spacing="2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/reports" />
    <MudText Typo="Typo.h5">@L["Title"]</MudText>
</MudStack>

@* Controls *@
<MudPaper Class="pa-4 mb-4" Elevation="1">

    @* Primary period presets *@
    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-3">
        <MudButton Variant="@PresetVariant("Preset_ThisMonth")"   Color="Color.Primary" Size="Size.Small" OnClick="@(() => ApplyPreset("Preset_ThisMonth"))">@L["Preset_ThisMonth"]</MudButton>
        <MudButton Variant="@PresetVariant("Preset_LastMonth")"   Color="Color.Primary" Size="Size.Small" OnClick="@(() => ApplyPreset("Preset_LastMonth"))">@L["Preset_LastMonth"]</MudButton>
        <MudButton Variant="@PresetVariant("Preset_ThisQuarter")" Color="Color.Primary" Size="Size.Small" OnClick="@(() => ApplyPreset("Preset_ThisQuarter"))">@L["Preset_ThisQuarter"]</MudButton>
        <MudButton Variant="@PresetVariant("Preset_Ytd")"         Color="Color.Primary" Size="Size.Small" OnClick="@(() => ApplyPreset("Preset_Ytd"))">@L["Preset_Ytd"]</MudButton>
        <MudButton Variant="@PresetVariant("Preset_LastYear")"    Color="Color.Primary" Size="Size.Small" OnClick="@(() => ApplyPreset("Preset_LastYear"))">@L["Preset_LastYear"]</MudButton>
    </MudStack>

    @* Primary period pickers + toggles *@
    <MudStack Row="true" AlignItems="AlignItems.End" Spacing="3" Wrap="Wrap.Wrap">
        <MudDatePicker Label="@L["From"]"
                       Date="_from" DateChanged="OnFromChanged"
                       DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today"
                       Style="max-width:180px" />
        <MudDatePicker Label="@L["To"]"
                       Date="_to" DateChanged="OnToChanged"
                       DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today"
                       Style="max-width:180px" />
        <MudSwitch @bind-Value="_hideZero" Label="@L["HideZero"]" Color="Color.Primary" />
        <MudSwitch Value="_compEnabled"
                   ValueChanged="@((bool v) => OnCompEnabledChanged(v))"
                   Label="@L["Compare"]" Color="Color.Secondary" />
        <MudSwitch Value="_budgetEnabled"
                   ValueChanged="@((bool v) => OnBudgetEnabledChanged(v))"
                   Label="@L["Budget_Toggle"]" Color="Color.Tertiary" />
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="GenerateAsync" Disabled="_loading">
            @L["Generate"]
        </MudButton>
        @if (_report is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PictureAsPdf"
                       OnClick="ExportPdfAsync" Disabled="_loading">
                @L["ExportPdf"]
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.TableChart"
                       OnClick="ExportCsvAsync" Disabled="_loading">
                @L["ExportCsv"]
            </MudButton>
        }
    </MudStack>

    @* Comparison period controls *@
    @if (_compEnabled)
    {
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color:#555">@L["ComparisonPeriod"]</MudText>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-2">
            <MudButton Variant="@CompPresetVariant("CompPreset_PriorMonth")"   Color="Color.Secondary" Size="Size.Small" OnClick="@(() => ApplyCompPreset("CompPreset_PriorMonth"))">@L["CompPreset_PriorMonth"]</MudButton>
            <MudButton Variant="@CompPresetVariant("CompPreset_PriorQuarter")" Color="Color.Secondary" Size="Size.Small" OnClick="@(() => ApplyCompPreset("CompPreset_PriorQuarter"))">@L["CompPreset_PriorQuarter"]</MudButton>
            <MudButton Variant="@CompPresetVariant("CompPreset_PriorYear")"    Color="Color.Secondary" Size="Size.Small" OnClick="@(() => ApplyCompPreset("CompPreset_PriorYear"))">@L["CompPreset_PriorYear"]</MudButton>
            <MudButton Variant="@CompPresetVariant(null)"                      Color="Color.Secondary" Size="Size.Small" OnClick="@(() => _compActivePreset = null)">@L["CompPreset_Custom"]</MudButton>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="3" Wrap="Wrap.Wrap">
            <MudDatePicker Label="@L["From"]"
                           Date="_compFrom" DateChanged="@(d => { _compFrom = d; _compActivePreset = null; })"
                           DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today"
                           Style="max-width:180px" />
            <MudDatePicker Label="@L["To"]"
                           Date="_compTo" DateChanged="@(d => { _compTo = d; _compActivePreset = null; })"
                           DateFormat="dd/MM/yyyy" MaxDate="DateTime.Today"
                           Style="max-width:180px" />
        </MudStack>
    }
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

@* Skeleton shown before first generate *@
@if (_report is null && !_loading)
{
    <MudPaper Class="pa-4" Elevation="1">
        @for (var i = 0; i < 10; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="@(i % 3 == 0 ? "55%" : i % 3 == 1 ? "40%" : "70%")"
                         Height="20px" Class="my-2" />
        }
    </MudPaper>
}

@* Report *@
@if (_report is not null)
{
    @* Subtitle *@
    <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-4" Style="font-style:italic">
        @if (_compReport is not null)
        {
            @string.Format(L["ReportTitleVs"].Value,
                $"{_compReport.Current.From.ToString("d MMM yyyy", CultureInfo.CurrentCulture)} – {_compReport.Current.To.ToString("d MMM yyyy", CultureInfo.CurrentCulture)}",
                $"{_compReport.Comparison.From.ToString("d MMM yyyy", CultureInfo.CurrentCulture)} – {_compReport.Comparison.To.ToString("d MMM yyyy", CultureInfo.CurrentCulture)}")
        }
        else
        {
            @string.Format(L["ReportTitle"].Value,
                _report.From.ToString("d MMMM yyyy", CultureInfo.CurrentCulture),
                _report.To.ToString("d MMMM yyyy", CultureInfo.CurrentCulture))
        }
    </MudText>

    @* No-budget alert *@
    @if (_budgetEnabled && _noBudget)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            @L["Budget_NoBudget"] <a href="/budgets">@L["Budget_CreateLink"]</a>
        </MudAlert>
    }

    @* ══════════════════════════════════════════════════════════════════════
       COMPARISON MODE
       ══════════════════════════════════════════════════════════════════════ *@
    @if (_compReport is not null)
    {
        @if (!_compReport.Lines.Any())
        {
            <MudAlert Severity="Severity.Info">@L["NoData"]</MudAlert>
        }
        else
        {
            @* Column headers *@
            <div style="display:flex;align-items:center;padding:4px 0;border-bottom:2px solid #CCC;margin-bottom:6px">
                <span style="min-width:80px"></span>
                <span style="flex:1"></span>
                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">
                    @_compReport.Current.From.ToString("dd/MM/yy") – @_compReport.Current.To.ToString("dd/MM/yy")
                </span>
                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#888;font-weight:600">
                    @_compReport.Comparison.From.ToString("dd/MM/yy") – @_compReport.Comparison.To.ToString("dd/MM/yy")
                </span>
                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">
                    @L["Col_Variance"]
                </span>
                <span style="min-width:72px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">
                    @L["Col_VarPct"]
                </span>
            </div>

            @* ── Revenue ── *@
            var compRevLines = _compReport.Lines.Where(l => l.Group == PnlGroup.Revenue).ToList();
            @if (compRevLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Revenue"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in compRevLines)
                    {
                        <div class="pnl-line-clickable" style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0" @onclick="@(() => OpenCompLineAsync(line))">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span class="pnl-acct-name" style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Current.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Comparison.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var rv = _compReport.CurRevenue - _compReport.CompRevenue; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Revenue"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_compReport.CurRevenue.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_compReport.CompRevenue.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(rv)">@rv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(rv)">@FormatVarPct(VarPct(_compReport.CurRevenue,_compReport.CompRevenue))</span>
                    </div>
                </div>
            }

            @* ── COGS ── *@
            var compCogsLines = _compReport.Lines.Where(l => l.Group == PnlGroup.Cogs).ToList();
            @if (compCogsLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Cogs"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in compCogsLines)
                    {
                        <div class="pnl-line-clickable" style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0" @onclick="@(() => OpenCompLineAsync(line))">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span class="pnl-acct-name" style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Current.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Comparison.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var cv = _compReport.CurCogs - _compReport.CompCogs; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Cogs"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_compReport.CurCogs.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_compReport.CompCogs.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(cv)">@cv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(cv)">@FormatVarPct(VarPct(_compReport.CurCogs,_compReport.CompCogs))</span>
                    </div>
                </div>
            }

            @* ── Gross Profit ── *@
            var gpVar = _compReport.CurGross - _compReport.CompGross;
            <MudPaper Elevation="0" Class="my-3 pa-3" Style="@($"background:#F8F8F8;border-left:4px solid {SummaryVarColour(gpVar)}")">
                <div style="display:flex;align-items:center">
                    <span style="flex:1;font-size:1rem;font-weight:700;color:@SignedColour(_compReport.CurGross)">@L["GrossProfit"]</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SignedColour(_compReport.CurGross)">@_compReport.CurGross.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:#999">@_compReport.CompGross.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SummaryVarColour(gpVar)">@gpVar.ToString("N2")</span>
                    <span style="min-width:72px;text-align:right;font-weight:700;color:@SummaryVarColour(gpVar)">@FormatVarPct(VarPct(_compReport.CurGross,_compReport.CompGross))</span>
                </div>
            </MudPaper>

            @* ── Operating Expenses ── *@
            var compOpexLines = _compReport.Lines.Where(l => l.Group is PnlGroup.OperatingExpenses or PnlGroup.Depreciation).ToList();
            @if (compOpexLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_OpEx"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in compOpexLines)
                    {
                        <div class="pnl-line-clickable" style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0" @onclick="@(() => OpenCompLineAsync(line))">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span class="pnl-acct-name" style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Current.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Comparison.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var ov = _compReport.CurOpEx - _compReport.CompOpEx; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_OpEx"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_compReport.CurOpEx.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_compReport.CompOpEx.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(ov)">@ov.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(ov)">@FormatVarPct(VarPct(_compReport.CurOpEx,_compReport.CompOpEx))</span>
                    </div>
                </div>
            }

            @* ── EBITDA ── *@
            var ebitdaVar = _compReport.CurEbitda - _compReport.CompEbitda;
            <MudPaper Elevation="0" Class="my-3 pa-3" Style="@($"background:#F8F8F8;border-left:4px solid {SummaryVarColour(ebitdaVar)}")">
                <div style="display:flex;align-items:center">
                    <MudTooltip Text="@L["EbitdaTooltip"]" Placement="Placement.Right">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex:1">
                            <span style="font-size:1rem;font-weight:700;color:@SignedColour(_compReport.CurEbitda)">@L["Ebitda"]</span>
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Style="color:#AAA" />
                        </MudStack>
                    </MudTooltip>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SignedColour(_compReport.CurEbitda)">@_compReport.CurEbitda.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:#999">@_compReport.CompEbitda.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SummaryVarColour(ebitdaVar)">@ebitdaVar.ToString("N2")</span>
                    <span style="min-width:72px;text-align:right;font-weight:700;color:@SummaryVarColour(ebitdaVar)">@FormatVarPct(VarPct(_compReport.CurEbitda,_compReport.CompEbitda))</span>
                </div>
            </MudPaper>

            @* ── Interest ── *@
            var compIntLines = _compReport.Lines.Where(l => l.Group == PnlGroup.Interest).ToList();
            @if (compIntLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Interest"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in compIntLines)
                    {
                        <div class="pnl-line-clickable" style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0" @onclick="@(() => OpenCompLineAsync(line))">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span class="pnl-acct-name" style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Current.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Comparison.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var iv = _compReport.CurInterest - _compReport.CompInterest; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Interest"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_compReport.CurInterest.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_compReport.CompInterest.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(iv)">@iv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(iv)">@FormatVarPct(VarPct(_compReport.CurInterest,_compReport.CompInterest))</span>
                    </div>
                </div>
            }

            @* ── Tax ── *@
            var compTaxLines = _compReport.Lines.Where(l => l.Group == PnlGroup.Tax).ToList();
            @if (compTaxLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Tax"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in compTaxLines)
                    {
                        <div class="pnl-line-clickable" style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0" @onclick="@(() => OpenCompLineAsync(line))">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span class="pnl-acct-name" style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Current.ToString("N2")</span>
