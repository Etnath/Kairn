@inject IStringLocalizer<ArAging> L
@inject IReminderService ReminderService
@inject ICurrentUserContext CurrentUser
@inject ISnackbar Snackbar

<MudDialog Style="min-width:600px;max-width:900px">
    <TitleContent>
        <MudText Typo="Typo.h6">@L["Bulk_Title"]</MudText>
    </TitleContent>
    <DialogContent>
        @if (_result is not null)
        {
            <MudAlert Severity="Severity.Success">
                @string.Format(L["Bulk_Result"].Value, _result.Sent, _result.Skipped)
            </MudAlert>
            @if (_result.Errors.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-2">
                    @foreach (var err in _result.Errors)
                    {
                        <div>@err</div>
                    }
                </MudAlert>
            }
        }
        else if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-3">@L["Bulk_Intro"]</MudText>
            <MudTable Items="_recipients" Dense="true" Elevation="0"
                      Style="border:1px solid var(--mud-palette-lines-default)">
                <HeaderContent>
                    <MudTh>@L["Bulk_Col_Customer"]</MudTh>
                    <MudTh>@L["Bulk_Col_Email"]</MudTh>
                    <MudTh Style="text-align:center">@L["Bulk_Col_Invoices"]</MudTh>
                    <MudTh Style="text-align:right">@L["Bulk_Col_Outstanding"]</MudTh>
                </HeaderContent>
                <RowTemplate Context="r">
                    <MudTd>@r.CustomerName</MudTd>
                    <MudTd>
                        @if (string.IsNullOrWhiteSpace(r.CustomerEmail))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Bulk_NoEmail"]</MudText>
                        }
                        else
                        {
                            @r.CustomerEmail
                        }
                    </MudTd>
                    <MudTd Style="text-align:center">@r.InvoiceCount</MudTd>
                    <MudTd Style="text-align:right;font-variant-numeric:tabular-nums">
                        @r.TotalOutstanding.ToString("N2")
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        @if (_result is not null)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">OK</MudButton>
        }
        else
        {
            <MudButton OnClick="Cancel" Disabled="_loading">@L["Cancel"]</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Send"
                       OnClick="ConfirmAsync" Disabled="_loading || _recipients.Count == 0">
                @L["Bulk_Confirm"]
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private List<BulkReminderRecipientDto> _recipients = [];
    private BulkReminderResultDto? _result;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _recipients = (await ReminderService.GetBulkPreviewAsync(CurrentUser.TenantId)).ToList();
        _loading = false;
    }

    private void Cancel() => MudDialog.Cancel();
    private void Close() => MudDialog.Close(DialogResult.Ok(true));

    private async Task ConfirmAsync()
    {
        _loading = true;
        _result = await ReminderService.SendBulkAsync(new SendBulkReminderCommand(
            TenantId: CurrentUser.TenantId,
            SentByUserId: CurrentUser.UserId,
            SentByName: CurrentUser.UserName));
        _loading = false;
    }
}
