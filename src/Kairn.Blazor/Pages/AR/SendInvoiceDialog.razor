@inject IStringLocalizer<Invoices> L
@inject IInvoiceService InvoiceService
@inject ICurrentUserContext CurrentUser
@inject IAccountService AccountService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText>@string.Format(L["Send_Confirm"].Value, Invoice!.Reference, Invoice.CustomerName)</MudText>

            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Send_Net"]</MudText>
                    <MudText Typo="Typo.body1"><b>@Invoice.Currency @Invoice.Subtotal.ToString("N2")</b></MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Send_Tax"]</MudText>
                    <MudText Typo="Typo.body1">@Invoice.Currency @Invoice.TotalTax.ToString("N2")</MudText>
                </MudItem>
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@L["Send_Total"]</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Primary">@Invoice.Currency @Invoice.GrandTotal.ToString("N2")</MudText>
                </MudItem>
            </MudGrid>

            <MudSelect T="Guid?" @bind-Value="_revenueAccountId"
                       Label="@L["Send_RevenueAccount"]"
                       Required="true"
                       HelperText="@L["Send_RevenueAccountHint"]">
                @foreach (var acc in _revenueAccounts)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)acc.Id)">@acc.Code – @acc.Name</MudSelectItem>
                }
            </MudSelect>

            @if (_errorMessage is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Confirm" Disabled="@(_saving || _revenueAccountId is null)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["Send_Send"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public InvoiceDto? Invoice { get; set; }

    private List<Kairn.Domain.Entities.Account> _revenueAccounts = [];
    private Guid? _revenueAccountId;
    private bool _saving;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var all = await AccountService.GetAllAsync(CurrentUser.TenantId);
        _revenueAccounts = all
            .Where(a => a.Type == Kairn.Domain.Entities.AccountType.Revenue && a.IsActive)
            .OrderBy(a => a.Code)
            .ToList();

        _revenueAccountId = Invoice?.RevenueAccountId;
        if (_revenueAccountId is null && _revenueAccounts.Count == 1)
            _revenueAccountId = _revenueAccounts[0].Id;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Confirm()
    {
        if (_revenueAccountId is null) return;

        _saving = true;
        _errorMessage = null;

        var result = await InvoiceService.SendAsync(new SendInvoiceCommand(
            Invoice!.Id,
            CurrentUser.TenantId,
            _revenueAccountId.Value,
            CurrentUser.UserId,
            CurrentUser.UserName));

        _saving = false;

        if (result.IsSuccess)
            MudDialog.Close(DialogResult.Ok(result.Value));
        else
            _errorMessage = result.Error;
    }
}
