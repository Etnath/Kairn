@page "/invoicing"
@attribute [Authorize(Roles = "Admin,Bookkeeper,Viewer")]
@inject IStringLocalizer<Invoices> L
@inject IStringLocalizer<InvoiceStatusChip> StatusL
@inject IInvoiceService InvoiceService
@inject ICustomerService CustomerService
@inject ICurrentUserContext CurrentUser
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>@L["Title"] – Kairn</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">@L["Title"]</MudText>
    <MudSpacer />
    <AuthorizeView Roles="Admin,Bookkeeper">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navigation.NavigateTo("/invoices/new"))">
            @L["NewInvoice"]
        </MudButton>
    </AuthorizeView>
</MudStack>

@* Filters *@
<MudGrid Spacing="2" Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudSelect T="Guid?" @bind-Value="_customerId" Label="@L["Filter_Customer"]"
                   Clearable="true" Dense="true">
            @foreach (var c in _customers)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="3">
        <MudSelect T="InvoiceStatus?" @bind-Value="_statusFilter" Label="@L["Filter_Status"]"
                   Clearable="true" Dense="true">
            @foreach (InvoiceStatus s in Enum.GetValues<InvoiceStatus>())
            {
                <MudSelectItem T="InvoiceStatus?" Value="@((InvoiceStatus?)s)">@StatusL[s.ToString()]</MudSelectItem>
            }
        </MudSelect>
    </MudItem>
    <MudItem xs="12" sm="2">
        <MudDatePicker @bind-Date="_from" Label="@L["Filter_From"]"
                       DateFormat="dd/MM/yyyy" Editable="true" Dense="true" />
    </MudItem>
    <MudItem xs="12" sm="2">
        <MudDatePicker @bind-Date="_to" Label="@L["Filter_To"]"
                       DateFormat="dd/MM/yyyy" Editable="true" Dense="true" />
    </MudItem>
    <MudItem xs="12" sm="2" Class="d-flex align-center gap-2">
        <MudSwitch @bind-Value="_showAll" Label="@L["Filter_ShowAll"]"
                   Color="Color.Primary" Size="Size.Small" />
        <MudButton Variant="Variant.Outlined" OnClick="ResetFilters" Size="Size.Small">
            @L["Filter_Reset"]
        </MudButton>
    </MudItem>
</MudGrid>

<MudTable T="InvoiceDto" ServerData="LoadData" @ref="_table" Dense="true" Hover="true"
          OnRowClick="OnRowClick" RowClass="cursor-pointer"
          RowStyleFunc="RowStyle"
          Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>@L["Col_Reference"]</MudTh>
        <MudTh>@L["Col_Customer"]</MudTh>
        <MudTh Style="width:110px">@L["Col_Date"]</MudTh>
        <MudTh Style="width:110px">@L["Col_DueDate"]</MudTh>
        <MudTh Style="width:100px">@L["Col_Status"]</MudTh>
        <MudTh Style="width:130px" Class="text-right">@L["Col_Amount"]</MudTh>
        <MudTh Style="width:60px"></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@L["Col_Reference"]">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.body2"><b>@context.Reference</b></MudText>
                @if (context.IsCreditNote)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Style="height:18px;font-size:10px">
                        @L["CreditNote_Label"]
                    </MudChip>
                }
            </MudStack>
        </MudTd>
        <MudTd DataLabel="@L["Col_Customer"]">@context.CustomerName</MudTd>
        <MudTd DataLabel="@L["Col_Date"]">@context.Date.ToString("dd/MM/yyyy")</MudTd>
        <MudTd DataLabel="@L["Col_DueDate"]">
            @if (!context.IsCreditNote)
            {
                <MudText Color="@(context.Status == InvoiceStatus.Overdue ? Color.Error : Color.Default)">
                    @context.DueDate.ToString("dd/MM/yyyy")
                </MudText>
            }
            else
            {
                <MudText Color="Color.Default">—</MudText>
            }
        </MudTd>
        <MudTd DataLabel="@L["Col_Status"]">
            @if (!context.IsCreditNote)
            {
                <InvoiceStatusChip Status="context.Status" />
            }
        </MudTd>
        <MudTd DataLabel="@L["Col_Amount"]" Class="text-right">
            @if (context.IsCreditNote)
            {
                <MudText Color="Color.Warning">– @context.Currency @context.GrandTotal.ToString("N2")</MudText>
            }
            else
            {
                @context.Currency @context.GrandTotal.ToString("N2")
            }
        </MudTd>
        <MudTd @onclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                           title="@L["Open"]"
                           OnClick="@(() => Navigation.NavigateTo($"/invoices/{context.Id}"))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Color="Color.Secondary">@L["NoInvoices"]</MudText>
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private MudTable<InvoiceDto> _table = null!;
    private IReadOnlyList<CustomerDto> _customers = [];
    private Guid? _customerId;
    private InvoiceStatus? _statusFilter;
    private DateTime? _from;
    private DateTime? _to;
    private bool _showAll;

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.GetAllAsync(CurrentUser.TenantId);
    }

    private async Task<TableData<InvoiceDto>> LoadData(TableState state, CancellationToken ct)
    {
        var query = new InvoiceQuery(
            TenantId: CurrentUser.TenantId,
            CustomerId: _customerId,
            Status: _statusFilter,
            From: _from.HasValue ? DateOnly.FromDateTime(_from.Value) : null,
            To: _to.HasValue ? DateOnly.FromDateTime(_to.Value) : null,
            Page: state.Page + 1,
            PageSize: state.PageSize,
            ExcludeClosedStatuses: !_showAll && _statusFilter is null);

        var result = await InvoiceService.GetPagedAsync(query, ct);
        return new TableData<InvoiceDto> { Items = result.Items, TotalItems = result.TotalCount };
    }

    private void OnRowClick(TableRowClickEventArgs<InvoiceDto> args) =>
        Navigation.NavigateTo($"/invoices/{args.Item!.Id}");

    private void ResetFilters()
    {
        _customerId = null;
        _statusFilter = null;
        _from = null;
        _to = null;
        _showAll = false;
        _table.ReloadServerData();
    }

    private static string RowStyle(InvoiceDto invoice, int _) =>
        invoice.Status == InvoiceStatus.Overdue ? "background-color:#FAECE8" : string.Empty;
}
