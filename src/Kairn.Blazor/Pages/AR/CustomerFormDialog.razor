@inject ICustomerService CustomerService
@inject ICurrentUserContext CurrentUser
@inject IStringLocalizer<Customers> L

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_model.Name" Label="@L["Field_Name"]"
                              Required="true" RequiredError="@L["Field_Name"]"
                              Immediate="true" />
                <MudTextField @bind-Value="_model.Email" Label="@L["Field_Email"]"
                              InputType="InputType.Email" Immediate="true" />
                <MudTextField @bind-Value="_model.Phone" Label="@L["Field_Phone"]"
                              Immediate="true" />
                <MudTextField @bind-Value="_model.Address" Label="@L["Field_Address"]"
                              Lines="3" Immediate="true" />
                <MudTextField @bind-Value="_model.TaxNumber" Label="@L["Field_TaxNumber"]"
                              Immediate="true" />
                <MudNumericField T="int" @bind-Value="_model.PaymentTermsDays"
                                 Label="@L["Field_PaymentTerms"]"
                                 Min="0" Max="365" Immediate="true" />
                <MudNumericField T="decimal?" @bind-Value="_model.CreditLimit"
                                 Label="@L["Field_CreditLimit"]"
                                 Min="0" Format="N2" Clearable="true" Immediate="true" />
                <MudTextField @bind-Value="_model.Currency" Label="@L["Field_Currency"]"
                              Required="true" RequiredError="@L["Field_Currency"]"
                              MaxLength="3" Immediate="true" />
                @if (_isEdit)
                {
                    <MudSwitch T="bool" @bind-Value="_model.IsActive"
                               Label="@L["Field_Active"]" Color="Color.Primary" />
                    @if (!_model.IsActive)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">
                            @L["InactiveNote"]
                        </MudText>
                    }
                }
                @if (_errorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
                }
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CustomerDto? Customer { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private bool _isEdit;
    private string? _errorMessage;
    private CustomerFormModel _model = new();

    protected override void OnParametersSet()
    {
        _isEdit = Customer is not null;
        if (_isEdit)
        {
            _model = new CustomerFormModel
            {
                Name = Customer!.Name,
                Email = Customer.Email ?? "",
                Phone = Customer.Phone ?? "",
                Address = Customer.Address ?? "",
                TaxNumber = Customer.TaxNumber ?? "",
                PaymentTermsDays = Customer.PaymentTermsDays,
                CreditLimit = Customer.CreditLimit,
                Currency = Customer.Currency,
                IsActive = Customer.IsActive,
            };
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _saving = true;
        _errorMessage = null;

        Result<CustomerDto> result;
        if (_isEdit)
        {
            result = await CustomerService.UpdateAsync(new UpdateCustomerCommand(
                Customer!.Id, CurrentUser.TenantId,
                _model.Name,
                NullIfEmpty(_model.Email), NullIfEmpty(_model.Phone),
                NullIfEmpty(_model.Address), NullIfEmpty(_model.TaxNumber),
                _model.PaymentTermsDays, _model.CreditLimit,
                _model.Currency, _model.IsActive));
        }
        else
        {
            result = await CustomerService.CreateAsync(new CreateCustomerCommand(
                CurrentUser.TenantId,
                _model.Name,
                NullIfEmpty(_model.Email), NullIfEmpty(_model.Phone),
                NullIfEmpty(_model.Address), NullIfEmpty(_model.TaxNumber),
                _model.PaymentTermsDays, _model.CreditLimit,
                _model.Currency));
        }

        _saving = false;

        if (result.IsSuccess)
            MudDialog.Close(DialogResult.Ok(result.Value));
        else
            _errorMessage = result.Error;
    }

    private static string? NullIfEmpty(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private class CustomerFormModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Address { get; set; } = "";
        public string TaxNumber { get; set; } = "";
        public int PaymentTermsDays { get; set; } = 30;
        public decimal? CreditLimit { get; set; }
        public string Currency { get; set; } = "EUR";
        public bool IsActive { get; set; } = true;
    }
}
