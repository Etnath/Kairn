@page "/account/reset-password-confirmation"
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password reset – Kairn</title>
    <link rel="stylesheet" href="~/app.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" />
    <style>
        body { background: #F5F4F1; font-family: Inter, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .card { background: #fff; border: 1px solid #D6D3CA; border-radius: 8px; padding: 2rem 2.5rem; width: 100%; max-width: 400px; box-shadow: 0 2px 8px rgba(0,0,0,.08); text-align: center; }
        h1 { color: #1F1E1C; font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; }
        p { color: #8C8980; font-size: 0.875rem; line-height: 1.5; }
        .icon { font-size: 2.5rem; margin-bottom: 1rem; }
        .btn { display: inline-block; margin-top: 1.25rem; background: #3A9463; color: #fff; border: none; border-radius: 4px; padding: .625rem 1.5rem; font-size: .875rem; font-weight: 600; cursor: pointer; font-family: inherit; text-decoration: none; }
        .btn:hover { background: #1F6040; }
    </style>
</head>
<body>
    <div class="card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <img src="/Logo.png" alt="Kairn" style="height:36px;" />
        </div>
        <div class="icon">✅</div>
        <h1>Password reset</h1>
        <p>Your password has been updated successfully. You can now sign in with your new password.</p>
        <a class="btn" href="/account/login">Sign in</a>
    </div>
</body>
</html>
