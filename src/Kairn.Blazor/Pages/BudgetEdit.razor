@page "/budgets/{Id:guid}"
@attribute [Authorize(Roles = "Admin,Bookkeeper,Viewer")]
@inject IStringLocalizer<BudgetEdit> L
@inject IBudgetService BudgetService
@inject ICurrentUserContext CurrentUser
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(_detail is null ? L["Title", "…", "…"] : string.Format(L["Title"], _detail.FiscalYear, _detail.Name)) – Kairn</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_detail is null)
{
    <MudAlert Severity="Severity.Error">@L["NotFound"]</MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                       Title="@L["Back"]"
                       OnClick="@(() => Nav.NavigateTo("/budgets"))" />
        <MudText Typo="Typo.h5">@string.Format(L["Title"], _detail.FiscalYear, _detail.Name)</MudText>
        <MudSpacer />
        <AuthorizeView Roles="Admin,Bookkeeper">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    @L["Saving"]
                }
                else
                {
                    @L["Save"]
                }
            </MudButton>
        </AuthorizeView>
    </MudStack>

    <AuthorizeView Roles="Viewer">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">@L["ReadOnly"]</MudAlert>
    </AuthorizeView>

    @* Revenue section *@
    <MudText Typo="Typo.h6" Class="mb-2">@L["Section_Revenue"]</MudText>
    <div style="overflow-x:auto; margin-bottom:2rem;">
        <table class="budget-grid">
            <thead>
                <tr>
                    <th class="col-code">@L["Col_Code"]</th>
                    <th class="col-name">@L["Col_Account"]</th>
                    @foreach (var mKey in MonthKeys)
                    {
                        <th class="col-month">@L[mKey]</th>
                    }
                    <th class="col-total">@L["Col_Total"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _detail.RevenueRows)
                {
                    <tr>
                        <td class="col-code mono">@row.Code</td>
                        <td class="col-name">@row.Name</td>
                        @for (int m = 0; m < 12; m++)
                        {
                            var month = m;
                            var acctId = row.AccountId;
                            <td class="col-month">
                                <AuthorizeView Roles="Admin,Bookkeeper">
                                    <input type="number" step="0.01"
                                           class="budget-input"
                                           value="@AmountStr(_grid[acctId][month])"
                                           @onchange="@(e => OnCellChange(acctId, month, e))" />
                                </AuthorizeView>
                                <AuthorizeView Roles="Viewer">
                                    <span class="budget-readonly">@AmountStr(_grid[acctId][month])</span>
                                </AuthorizeView>
                            </td>
                        }
                        <td class="col-total total-cell">@AmountStr(_grid[row.AccountId].Sum())</td>
                    </tr>
                }
                <tr class="subtotal-row">
                    <td colspan="2" class="col-name"><strong>@L["Row_Total"]</strong></td>
                    @for (int m = 0; m < 12; m++)
                    {
                        var month = m;
                        <td class="col-month total-cell">
                            <strong>@AmountStr(_detail.RevenueRows.Sum(r => _grid[r.AccountId][month]))</strong>
                        </td>
                    }
                    <td class="col-total total-cell">
                        <strong>@AmountStr(_detail.RevenueRows.Sum(r => _grid[r.AccountId].Sum()))</strong>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* Expense section *@
    <MudText Typo="Typo.h6" Class="mb-2">@L["Section_Expense"]</MudText>
    <div style="overflow-x:auto; margin-bottom:2rem;">
        <table class="budget-grid">
            <thead>
                <tr>
                    <th class="col-code">@L["Col_Code"]</th>
                    <th class="col-name">@L["Col_Account"]</th>
                    @foreach (var mKey in MonthKeys)
                    {
                        <th class="col-month">@L[mKey]</th>
                    }
                    <th class="col-total">@L["Col_Total"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _detail.ExpenseRows)
                {
                    <tr>
                        <td class="col-code mono">@row.Code</td>
                        <td class="col-name">@row.Name</td>
                        @for (int m = 0; m < 12; m++)
                        {
                            var month = m;
                            var acctId = row.AccountId;
                            <td class="col-month">
                                <AuthorizeView Roles="Admin,Bookkeeper">
                                    <input type="number" step="0.01"
                                           class="budget-input"
                                           value="@AmountStr(_grid[acctId][month])"
                                           @onchange="@(e => OnCellChange(acctId, month, e))" />
                                </AuthorizeView>
                                <AuthorizeView Roles="Viewer">
                                    <span class="budget-readonly">@AmountStr(_grid[acctId][month])</span>
                                </AuthorizeView>
                            </td>
                        }
                        <td class="col-total total-cell">@AmountStr(_grid[row.AccountId].Sum())</td>
                    </tr>
                }
                <tr class="subtotal-row">
                    <td colspan="2" class="col-name"><strong>@L["Row_Total"]</strong></td>
                    @for (int m = 0; m < 12; m++)
                    {
                        var month = m;
                        <td class="col-month total-cell">
                            <strong>@AmountStr(_detail.ExpenseRows.Sum(r => _grid[r.AccountId][month]))</strong>
                        </td>
                    }
                    <td class="col-total total-cell">
                        <strong>@AmountStr(_detail.ExpenseRows.Sum(r => _grid[r.AccountId].Sum()))</strong>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    @* Net income summary *@
    var totalRevenue = _detail.RevenueRows.Sum(r => _grid[r.AccountId].Sum());
    var totalExpense = _detail.ExpenseRows.Sum(r => _grid[r.AccountId].Sum());
    var netIncome = totalRevenue - totalExpense;
    <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="display:inline-block; min-width:280px;">
        <MudStack Spacing="1">
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.body2">@L["Section_Revenue"]</MudText>
                <MudText Typo="Typo.body2" Style="font-family:monospace">@totalRevenue.ToString("N2")</MudText>
            </MudStack>
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.body2">@L["Section_Expense"]</MudText>
                <MudText Typo="Typo.body2" Style="font-family:monospace">@totalExpense.ToString("N2")</MudText>
            </MudStack>
            <MudDivider />
            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle2"><strong>@L["Row_Net"]</strong></MudText>
                <MudText Typo="Typo.subtitle2" Style="@($"font-family:monospace; color:{NetColour(netIncome)}")">
                    <strong>@netIncome.ToString("N2")</strong>
                </MudText>
            </MudStack>
        </MudStack>
    </MudPaper>
}

<style>
    .budget-grid {
        border-collapse: collapse;
        width: 100%;
        min-width: 900px;
        font-size: 0.85rem;
    }
    .budget-grid th, .budget-grid td {
        border: 1px solid var(--mud-palette-table-lines);
        padding: 4px 6px;
        white-space: nowrap;
    }
    .budget-grid th {
        background: var(--mud-palette-table-header);
        font-weight: 600;
        text-align: center;
    }
    .col-code { width: 80px; text-align: center; }
    .col-name { min-width: 160px; max-width: 240px; text-align: left; }
    .col-month { width: 72px; text-align: right; }
    .col-total { width: 90px; text-align: right; font-weight: 600; }
    .mono { font-family: monospace; }
    .total-cell { background: var(--mud-palette-background-grey); }
    .subtotal-row td { background: var(--mud-palette-background-grey); }
    .budget-input {
        width: 100%;
        border: none;
        background: transparent;
        text-align: right;
        font-size: inherit;
        color: inherit;
        outline: none;
        padding: 0;
    }
    .budget-input:focus {
        background: var(--mud-palette-primary-lighten);
    }
    .budget-readonly {
        display: block;
        text-align: right;
    }
</style>

@code {
    [Parameter] public Guid Id { get; set; }

    private static readonly string[] MonthKeys =
        ["Col_Jan", "Col_Feb", "Col_Mar", "Col_Apr", "Col_May", "Col_Jun",
         "Col_Jul", "Col_Aug", "Col_Sep", "Col_Oct", "Col_Nov", "Col_Dec"];

    private bool _loading = true;
    private bool _saving;
    private BudgetDetailDto? _detail;
    private Dictionary<Guid, decimal[]> _grid = new();

    protected override async Task OnInitializedAsync()
    {
        _detail = await BudgetService.GetDetailAsync(CurrentUser.TenantId, Id);
        if (_detail is not null)
        {
            foreach (var row in _detail.RevenueRows.Concat(_detail.ExpenseRows))
                _grid[row.AccountId] = (decimal[])row.Amounts.Clone();
        }
        _loading = false;
    }

    private void OnCellChange(Guid accountId, int monthIndex, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
            _grid[accountId][monthIndex] = val;
        else
            _grid[accountId][monthIndex] = 0m;
    }

    private async Task SaveAsync()
    {
        if (_detail is null) return;

        _saving = true;
        var lines = new List<BudgetLineValue>();

        foreach (var (acctId, amounts) in _grid)
        {
            for (int m = 0; m < 12; m++)
            {
                if (amounts[m] != 0m)
                    lines.Add(new BudgetLineValue(acctId, m + 1, amounts[m]));
            }
        }

        var result = await BudgetService.SaveLinesAsync(
            new SaveBudgetLinesCommand(CurrentUser.TenantId, _detail.Id, lines));

        _saving = false;

        if (result.IsSuccess)
            Snackbar.Add(L["Saved"], Severity.Success);
        else
            Snackbar.Add(result.Error ?? "Error", Severity.Error);
    }

    private static string AmountStr(decimal v) =>
        v == 0m ? "" : v.ToString("N2");

    private static string NetColour(decimal net) =>
        net >= 0m ? "#1F6040" : "#7E2A14";
}
