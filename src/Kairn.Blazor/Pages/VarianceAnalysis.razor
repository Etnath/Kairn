@page "/budgets/variance"
@attribute [Authorize]
@using System.Globalization
@inject IStringLocalizer<VarianceAnalysis> L
@inject IPnlService PnlService
@inject IPnlExporter PnlExporter
@inject IBudgetService BudgetService
@inject IJSRuntime JS
@inject ICurrentUserContext CurrentUser

<PageTitle>@L["Title"] – Kairn</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Spacing="2">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/budgets" />
    <MudText Typo="Typo.h5">@L["Title"]</MudText>
</MudStack>

@if (_budgets.Count == 0 && !_loadingBudgets)
{
    <MudAlert Severity="Severity.Warning">
        @L["NoBudgets"] <a href="/budgets">@L["CreateBudgetLink"]</a>
    </MudAlert>
}
else
{
    @* Controls *@
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="3" Wrap="Wrap.Wrap">
            <MudSelect T="int" Value="_selectedYear" ValueChanged="OnYearChanged"
                       Label="@L["FiscalYear"]" Style="max-width:140px">
                @foreach (var b in _budgets)
                {
                    <MudSelectItem T="int" Value="b.FiscalYear">@b.FiscalYear</MudSelectItem>
                }
            </MudSelect>
            <MudDatePicker Label="@L["From"]"
                           Date="_from" DateChanged="@(d => _from = d)"
                           DateFormat="dd/MM/yyyy"
                           Style="max-width:180px" />
            <MudDatePicker Label="@L["To"]"
                           Date="_to" DateChanged="@(d => _to = d)"
                           DateFormat="dd/MM/yyyy"
                           Style="max-width:180px" />
            <MudSwitch @bind-Value="_hideZero" Label="@L["HideZero"]" Color="Color.Primary" />
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="GenerateAsync" Disabled="_loading">
                @L["Generate"]
            </MudButton>
            @if (_budgetReport is not null)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           OnClick="ExportPdfAsync" Disabled="_loading">
                    @L["ExportPdf"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.TableChart"
                           OnClick="ExportCsvAsync" Disabled="_loading">
                    @L["ExportCsv"]
                </MudButton>
            }
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }

    @if (_noBudget && !_loading)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            @L["NoBudgetForPeriod"] <a href="/budgets">@L["CreateBudgetLink"]</a>
        </MudAlert>
    }

    @if (_budgetReport is not null && !_loading)
    {
        @* Subtitle *@
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-4" Style="font-style:italic">
            @string.Format(L["ReportSubtitle"], _selectedYear,
                _budgetReport.Actual.From.ToString("d MMM yyyy", CultureInfo.CurrentCulture),
                _budgetReport.Actual.To.ToString("d MMM yyyy", CultureInfo.CurrentCulture))
        </MudText>

        @if (!_budgetReport.Lines.Any())
        {
            <MudAlert Severity="Severity.Info">@L["NoData"]</MudAlert>
        }
        else
        {
            @* Net summary banner *@
            var budNetVar = _budgetReport.ActNet - _budgetReport.BudNet;
            <MudPaper Elevation="0" Class="mb-4 pa-3" Style="@($"background:#F3F8F5;border-left:4px solid {SummaryVarColour(budNetVar)}")">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Typo="Typo.subtitle2" Style="color:#555;font-weight:600">@L["NetSummaryLabel"]</MudText>
                    <MudSpacer />
                    <MudText Style="@($"font-variant-numeric:tabular-nums;font-weight:600;color:{SignedColour(_budgetReport.ActNet)}")">@_budgetReport.ActNet.ToString("N2")</MudText>
                    <MudText Style="color:#AAA">/</MudText>
                    <MudText Style="font-variant-numeric:tabular-nums;color:#999">@_budgetReport.BudNet.ToString("N2")</MudText>
                    <MudText Style="@($"font-variant-numeric:tabular-nums;font-weight:600;color:{SummaryVarColour(budNetVar)}")">@($"{budNetVar:+0.00;-0.00;0.00}")</MudText>
                    <MudText Style="@($"font-size:0.875rem;color:{SummaryVarColour(budNetVar)}")">@FormatVarPct(VarPct(_budgetReport.ActNet, _budgetReport.BudNet))</MudText>
                </MudStack>
            </MudPaper>

            @* Column headers *@
            <div style="display:flex;align-items:center;padding:4px 0;border-bottom:2px solid #CCC;margin-bottom:6px">
                <span style="min-width:80px"></span>
                <span style="flex:1"></span>
                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">@L["Col_Actual"]</span>
                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#888;font-weight:600">@L["Col_Budget"]</span>
                <span style="min-width:110px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">@L["Col_Variance"]</span>
                <span style="min-width:72px;text-align:right;font-size:0.75rem;color:#555;font-weight:600">@L["Col_VarPct"]</span>
            </div>

            @* ── Revenue ── *@
            var revLines = _budgetReport.Lines.Where(l => l.Group == PnlGroup.Revenue).ToList();
            @if (revLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Revenue"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in revLines)
                    {
                        <div style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Actual.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Budget.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var bRv = _budgetReport.ActRevenue - _budgetReport.BudRevenue; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Revenue"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_budgetReport.ActRevenue.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_budgetReport.BudRevenue.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(bRv)">@bRv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(bRv)">@FormatVarPct(VarPct(_budgetReport.ActRevenue,_budgetReport.BudRevenue))</span>
                    </div>
                </div>
            }

            @* ── COGS ── *@
            var cogsLines = _budgetReport.Lines.Where(l => l.Group == PnlGroup.Cogs).ToList();
            @if (cogsLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Cogs"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in cogsLines)
                    {
                        <div style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Actual.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Budget.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var bCv = _budgetReport.ActCogs - _budgetReport.BudCogs; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Cogs"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_budgetReport.ActCogs.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_budgetReport.BudCogs.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(bCv)">@bCv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(bCv)">@FormatVarPct(VarPct(_budgetReport.ActCogs,_budgetReport.BudCogs))</span>
                    </div>
                </div>
            }

            @* ── Gross Profit ── *@
            var gpVar = _budgetReport.ActGross - _budgetReport.BudGross;
            <MudPaper Elevation="0" Class="my-3 pa-3" Style="@($"background:#F8F8F8;border-left:4px solid {SummaryVarColour(gpVar)}")">
                <div style="display:flex;align-items:center">
                    <span style="flex:1;font-size:1rem;font-weight:700;color:@SignedColour(_budgetReport.ActGross)">@L["GrossProfit"]</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SignedColour(_budgetReport.ActGross)">@_budgetReport.ActGross.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:#999">@_budgetReport.BudGross.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SummaryVarColour(gpVar)">@gpVar.ToString("N2")</span>
                    <span style="min-width:72px;text-align:right;font-weight:700;color:@SummaryVarColour(gpVar)">@FormatVarPct(VarPct(_budgetReport.ActGross,_budgetReport.BudGross))</span>
                </div>
            </MudPaper>

            @* ── Operating Expenses ── *@
            var opexLines = _budgetReport.Lines.Where(l => l.Group is PnlGroup.OperatingExpenses or PnlGroup.Depreciation).ToList();
            @if (opexLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_OpEx"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in opexLines)
                    {
                        <div style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Actual.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Budget.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var bOv = _budgetReport.ActOpEx - _budgetReport.BudOpEx; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_OpEx"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_budgetReport.ActOpEx.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_budgetReport.BudOpEx.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(bOv)">@bOv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(bOv)">@FormatVarPct(VarPct(_budgetReport.ActOpEx,_budgetReport.BudOpEx))</span>
                    </div>
                </div>
            }

            @* ── EBITDA ── *@
            var ebitdaVar = _budgetReport.ActEbitda - _budgetReport.BudEbitda;
            <MudPaper Elevation="0" Class="my-3 pa-3" Style="@($"background:#F8F8F8;border-left:4px solid {SummaryVarColour(ebitdaVar)}")">
                <div style="display:flex;align-items:center">
                    <MudTooltip Text="@L["EbitdaTooltip"]" Placement="Placement.Right">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="flex:1">
                            <span style="font-size:1rem;font-weight:700;color:@SignedColour(_budgetReport.ActEbitda)">@L["Ebitda"]</span>
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Style="color:#AAA" />
                        </MudStack>
                    </MudTooltip>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SignedColour(_budgetReport.ActEbitda)">@_budgetReport.ActEbitda.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:#999">@_budgetReport.BudEbitda.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-weight:700;color:@SummaryVarColour(ebitdaVar)">@ebitdaVar.ToString("N2")</span>
                    <span style="min-width:72px;text-align:right;font-weight:700;color:@SummaryVarColour(ebitdaVar)">@FormatVarPct(VarPct(_budgetReport.ActEbitda,_budgetReport.BudEbitda))</span>
                </div>
            </MudPaper>

            @* ── Interest ── *@
            var intLines = _budgetReport.Lines.Where(l => l.Group == PnlGroup.Interest).ToList();
            @if (intLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Interest"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in intLines)
                    {
                        <div style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Actual.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Budget.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var bIv = _budgetReport.ActInterest - _budgetReport.BudInterest; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Interest"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_budgetReport.ActInterest.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_budgetReport.BudInterest.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(bIv)">@bIv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(bIv)">@FormatVarPct(VarPct(_budgetReport.ActInterest,_budgetReport.BudInterest))</span>
                    </div>
                </div>
            }

            @* ── Tax ── *@
            var taxLines = _budgetReport.Lines.Where(l => l.Group == PnlGroup.Tax).ToList();
            @if (taxLines.Count > 0)
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1" Style="text-transform:uppercase;letter-spacing:.06em;color:#555;font-weight:700">@L["Group_Tax"]</MudText>
                    <MudDivider Class="mb-1" />
                    @foreach (var line in taxLines)
                    {
                        <div style="display:flex;align-items:center;padding:3px 0;border-bottom:1px solid #F0F0F0">
                            <span style="min-width:80px;font-size:0.8125rem;color:#999">@line.AccountCode</span>
                            <span style="flex:1;font-size:0.8125rem">@line.AccountName</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums">@line.Actual.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:#999">@line.Budget.ToString("N2")</span>
                            <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;color:@VarColour(line.Variance,line.Group)">@line.Variance.ToString("N2")</span>
                            <span style="min-width:72px;text-align:right;font-size:0.8125rem;color:@VarColour(line.Variance,line.Group)">@FormatVarPct(line.VariancePct)</span>
                        </div>
                    }
                    @{ var bTv = _budgetReport.ActTax - _budgetReport.BudTax; }
                    <div style="display:flex;align-items:center;padding:4px 0;border-top:1px solid #CCC;margin-top:2px">
                        <span style="flex:1;font-size:0.8125rem;font-weight:600">@L["Sub_Tax"]</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600">@_budgetReport.ActTax.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:#999">@_budgetReport.BudTax.ToString("N2")</span>
                        <span style="min-width:110px;text-align:right;font-size:0.8125rem;font-variant-numeric:tabular-nums;font-weight:600;color:@SummaryVarColour(bTv)">@bTv.ToString("N2")</span>
                        <span style="min-width:72px;text-align:right;font-size:0.8125rem;font-weight:600;color:@SummaryVarColour(bTv)">@FormatVarPct(VarPct(_budgetReport.ActTax,_budgetReport.BudTax))</span>
                    </div>
                </div>
            }

            @* ── Net Income ── *@
            var niVar = _budgetReport.ActNet - _budgetReport.BudNet;
            <MudPaper Elevation="1" Class="my-3 pa-4" Style="@($"background:#FAFAFA;border-left:6px solid {SummaryVarColour(niVar)}")">
                <div style="display:flex;align-items:center">
                    <span style="flex:1;font-size:1.125rem;font-weight:700;color:@SignedColour(_budgetReport.ActNet)">@L["NetIncome"]</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-size:1.125rem;font-weight:700;color:@SignedColour(_budgetReport.ActNet)">@_budgetReport.ActNet.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-size:1.125rem;font-weight:700;color:#999">@_budgetReport.BudNet.ToString("N2")</span>
                    <span style="min-width:110px;text-align:right;font-variant-numeric:tabular-nums;font-size:1.125rem;font-weight:700;color:@SummaryVarColour(niVar)">@niVar.ToString("N2")</span>
                    <span style="min-width:72px;text-align:right;font-size:1.125rem;font-weight:700;color:@SummaryVarColour(niVar)">@FormatVarPct(VarPct(_budgetReport.ActNet,_budgetReport.BudNet))</span>
                </div>
            </MudPaper>
        }
    }
}

@code {
    private bool _loadingBudgets = true;
    private bool _loading;
    private bool _hideZero = true;
    private bool _noBudget;

    private List<BudgetSummaryDto> _budgets = [];
    private int _selectedYear;
    private DateTime? _from;
    private DateTime? _to;

    private PnlBudgetReport? _budgetReport;

    protected override async Task OnInitializedAsync()
    {
        var all = await BudgetService.GetAllAsync(CurrentUser.TenantId);
        _budgets = all.ToList();
        _loadingBudgets = false;

        if (_budgets.Count > 0)
        {
            _selectedYear = _budgets.Any(b => b.FiscalYear == DateTime.Today.Year)
                ? DateTime.Today.Year
                : _budgets[0].FiscalYear;
            ApplyYearDefaults(_selectedYear);
            await GenerateAsync();
        }
    }

    private void OnYearChanged(int year)
    {
        _selectedYear = year;
        ApplyYearDefaults(year);
    }

    private void ApplyYearDefaults(int year)
    {
        _from = new DateTime(year, 1, 1);
        _to   = new DateTime(year, 12, 31);
    }

    private async Task GenerateAsync()
    {
        if (_from is null || _to is null) return;
        _loading      = true;
        _noBudget     = false;
        _budgetReport = null;
        try
        {
            var from = DateOnly.FromDateTime(_from.Value);
            var to   = DateOnly.FromDateTime(_to.Value);

            var actual = await PnlService.GenerateAsync(
                new PnlQuery(CurrentUser.TenantId, from, to, _hideZero));

            _budgetReport = await PnlService.GetBudgetOverlayAsync(
                actual, CurrentUser.TenantId, from, to);

            _noBudget = _budgetReport is null;
        }
        finally { _loading = false; }
    }

    private async Task ExportPdfAsync()
    {
        if (_budgetReport is null) return;
        _loading = true;
        try
        {
            var meta  = PnlExportMeta.Now(CurrentUser.UserName);
            var bytes = PnlExporter.ToPdf(_budgetReport, meta);
            var fn    = $"VA_{_selectedYear}_{_budgetReport.Actual.From:yyyy-MM-dd}_{_budgetReport.Actual.To:yyyy-MM-dd}.pdf";
            await JS.InvokeVoidAsync("kairn.downloadFile", fn, "application/pdf", bytes);
        }
        finally { _loading = false; }
    }

    private async Task ExportCsvAsync()
    {
        if (_budgetReport is null) return;
        _loading = true;
        try
        {
            var meta = PnlExportMeta.Now(CurrentUser.UserName);
            var csv  = PnlExporter.ToCsv(_budgetReport, meta);
            var fn   = $"VA_{_selectedYear}_{_budgetReport.Actual.From:yyyy-MM-dd}_{_budgetReport.Actual.To:yyyy-MM-dd}.csv";
            await JS.InvokeVoidAsync("kairn.downloadFile", fn, "text/csv",
                System.Text.Encoding.UTF8.GetBytes(csv));
        }
        finally { _loading = false; }
    }

    private static string SignedColour(decimal v) =>
        v > 0 ? "#1F6040" : v < 0 ? "#7E2A14" : "#8C8980";

    private static string SummaryVarColour(decimal v) =>
        v > 0 ? "#1F6040" : v < 0 ? "#7E2A14" : "#8C8980";

    private static string VarColour(decimal variance, PnlGroup group)
    {
        if (variance == 0m) return "#8C8980";
        bool favorable = group == PnlGroup.Revenue ? variance > 0 : variance < 0;
        return favorable ? "#1F6040" : "#7E2A14";
    }

    private static string FormatVarPct(decimal? pct) =>
        pct.HasValue ? $"{pct.Value:+0.0;-0.0;0.0}%" : "N/A";

    private static decimal? VarPct(decimal current, decimal comparison) =>
        comparison == 0m ? null : Math.Round((current - comparison) / Math.Abs(comparison) * 100m, 1);
}
