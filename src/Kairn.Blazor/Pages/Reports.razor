@page "/reports"
@attribute [Authorize]
@inject IStringLocalizer<Reports> L

<PageTitle>@L["Title"] – Kairn</PageTitle>
<MudText Typo="Typo.h5" Class="mb-6">@L["Title"]</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Balance" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">@L["TrialBalance.Title"]</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["TrialBalance.Description"]</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="/reports/trial-balance" Variant="Variant.Text" Color="Color.Primary">
                    @L["Open"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">@L["ProfitLoss.Title"]</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["ProfitLoss.Description"]</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="/reports/profit-loss" Variant="Variant.Text" Color="Color.Primary">
                    @L["Open"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    @if (ProfileState?.IsAutoEntrepreneur != true)
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard>
                <MudCardContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">@L["BalanceSheet.Title"]</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["BalanceSheet.Description"]</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="/reports/balance-sheet" Variant="Variant.Text" Color="Color.Primary">
                        @L["Open"]
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    [CascadingParameter] public TenantProfileState? ProfileState { get; set; }
}
