@page "/reports"
@attribute [Authorize]
@inject IStringLocalizer<Reports> L

<PageTitle>@L["Title"] – Kairn</PageTitle>
<MudText Typo="Typo.h5" Class="mb-6">@L["Title"]</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Balance" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">@L["TrialBalance.Title"]</MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@L["TrialBalance.Description"]</MudText>
            </MudCardContent>
            <MudCardActions>
                <MudButton Href="/reports/trial-balance" Variant="Variant.Text" Color="Color.Primary">
                    @L["Open"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>
