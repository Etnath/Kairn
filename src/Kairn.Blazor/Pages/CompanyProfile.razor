@page "/settings/company-profile"
@attribute [Authorize(Roles = "Admin")]
@inject IStringLocalizer<CompanyProfile> L
@inject ITenantProfileService ProfileService
@inject ICurrentUserContext CurrentUser
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject TenantProfileState ProfileState

<PageTitle>@L["Title"] – Kairn</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                   OnClick="@(() => Nav.NavigateTo("/settings"))" />
    <MudText Typo="Typo.h5">@L["Title"]</MudText>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudStack Spacing="4" Style="max-width:620px">

        {{! ── Legal Identity ─────────────────────────── }}
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-3"><b>@L["Section_Identity"]</b></MudText>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_legalName"
                              Label="@L["Field_LegalName"]"
                              Required="true"
                              Immediate="true" />
                <MudTextField @bind-Value="_siret"
                              Label="@L["Field_Siret"]"
                              InputType="InputType.Text"
                              MaxLength="14"
                              Immediate="true" />
                <MudTextField @bind-Value="_addressLine"
                              Label="@L["Field_Address"]" />
                <MudStack Row="true" Spacing="2">
                    <MudTextField @bind-Value="_postalCode"
                                  Label="@L["Field_PostalCode"]"
                                  Style="max-width:130px" />
                    <MudTextField @bind-Value="_city"
                                  Label="@L["Field_City"]"
                                  Style="flex:1" />
                </MudStack>
                <MudTextField @bind-Value="_country"
                              Label="@L["Field_Country"]" />
            </MudStack>
        </MudPaper>

        {{! ── Business Status ────────────────────────── }}
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-3"><b>@L["Section_Status"]</b></MudText>
            <MudStack Spacing="2">
                <MudRadioGroup T="BusinessStatus" @bind-Value="_businessStatus">
                    <MudRadio T="BusinessStatus" Value="BusinessStatus.Standard" Color="Color.Primary">
                        @L["Status_Standard"]
                    </MudRadio>
                    <MudRadio T="BusinessStatus" Value="BusinessStatus.AutoEntrepreneur" Color="Color.Secondary">
                        @L["Status_AutoEntrepreneur"]
                    </MudRadio>
                </MudRadioGroup>

                @if (_businessStatus == BusinessStatus.AutoEntrepreneur)
                {
                    <MudDivider Class="my-2" />
                    <MudSelect T="ActivityType" @bind-Value="_activityType"
                               Label="@L["Field_ActivityType"]">
                        <MudSelectItem Value="ActivityType.Services">@L["Activity_Services"]</MudSelectItem>
                        <MudSelectItem Value="ActivityType.Commercial">@L["Activity_Commercial"]</MudSelectItem>
                    </MudSelect>
                }
            </MudStack>
        </MudPaper>

        {{! ── VAT Thresholds (auto-entrepreneur only) ── }}
        @if (_businessStatus == BusinessStatus.AutoEntrepreneur)
        {
            <MudPaper Class="pa-4" Elevation="0" Outlined="true">
                <MudText Typo="Typo.subtitle1" Class="mb-1"><b>@L["Section_Thresholds"]</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">@L["Threshold_Hint"]</MudText>
                <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                    <MudNumericField T="decimal" @bind-Value="_thresholdServices"
                                     Label="@L["Field_ThresholdServices"]"
                                     Format="N0" Min="1m" HideSpinButtons="true"
                                     Style="max-width:220px" />
                    <MudNumericField T="decimal" @bind-Value="_thresholdCommercial"
                                     Label="@L["Field_ThresholdCommercial"]"
                                     Format="N0" Min="1m" HideSpinButtons="true"
                                     Style="max-width:220px" />
                </MudStack>
            </MudPaper>
        }

        {{! ── Logo ───────────────────────────────────── }}
        <MudPaper Class="pa-4" Elevation="0" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-1"><b>@L["Section_Logo"]</b></MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">@L["Logo_Hint"]</MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                @if (_logoDataUrl is not null)
                {
                    <img src="@_logoDataUrl" alt="logo"
                         style="max-height:60px;max-width:180px;object-fit:contain;border:1px solid #ddd;border-radius:4px;padding:4px" />
                    <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                               OnClick="RemoveLogo">@L["Logo_Remove"]</MudButton>
                }
                <InputFile id="logoInput" OnChange="OnLogoSelected" accept=".png,.jpg,.jpeg" style="display:none" />
                <MudButton HtmlTag="label" for="logoInput"
                           Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Upload">
                    @L["Logo_Change"]
                </MudButton>
            </MudStack>
            @if (_logoError is not null)
            {
                <MudText Color="Color.Error" Typo="Typo.caption" Class="mt-1">@_logoError</MudText>
            }
        </MudPaper>

        {{! ── Actions ─────────────────────────────────── }}
        <MudStack Row="true" Justify="Justify.FlexEnd">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_saving || string.IsNullOrWhiteSpace(_legalName))"
                       OnClick="SaveAsync">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @L["Save"]
            </MudButton>
        </MudStack>

    </MudStack>
}

@code {
    private bool _loading = true;
    private bool _saving;

    private string _legalName     = "";
    private string _siret         = "";
    private string _addressLine   = "";
    private string _postalCode    = "";
    private string _city          = "";
    private string _country       = "France";
    private BusinessStatus _businessStatus = BusinessStatus.Standard;
    private ActivityType   _activityType   = ActivityType.Services;
    private decimal _thresholdServices   = 77_700m;
    private decimal _thresholdCommercial = 188_700m;

    private string? _logoDataUrl;
    private string? _pendingLogoDataUrl;
    private string? _logoError;

    protected override async Task OnInitializedAsync()
    {
        var dto = await ProfileService.GetAsync(CurrentUser.TenantId);
        _legalName            = dto.LegalName;
        _siret                = dto.Siret;
        _addressLine          = dto.AddressLine;
        _postalCode           = dto.PostalCode;
        _city                 = dto.City;
        _country              = dto.Country;
        _businessStatus       = dto.BusinessStatus;
        _activityType         = dto.ActivityType;
        _thresholdServices    = dto.VatThresholdServices;
        _thresholdCommercial  = dto.VatThresholdCommercial;
        _logoDataUrl          = dto.LogoPath;
        _loading = false;
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        _logoError = null;
        var file = e.File;

        if (file.Size > 1_048_576)
        {
            _logoError = "File exceeds 1 MB limit.";
            return;
        }
        if (!file.ContentType.StartsWith("image/"))
        {
            _logoError = "Only PNG and JPG files are accepted.";
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(1_048_576).CopyToAsync(ms);
        var bytes = ms.ToArray();
        _pendingLogoDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
        _logoDataUrl = _pendingLogoDataUrl;
    }

    private void RemoveLogo()
    {
        _logoDataUrl        = null;
        _pendingLogoDataUrl = null;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        var result = await ProfileService.SaveAsync(new SaveTenantProfileCommand(
            CurrentUser.TenantId,
            _legalName, _siret, _addressLine, _postalCode, _city, _country,
            _businessStatus, _activityType,
            _thresholdServices, _thresholdCommercial,
            LogoPath: _logoDataUrl,
            CurrentUser.UserId, CurrentUser.UserName));
        _saving = false;

        if (result.IsSuccess)
        {
            ProfileState.Notify(_businessStatus);
            Snackbar.Add(L["Saved"].Value, Severity.Success);
        }
        else
            Snackbar.Add(result.Error, Severity.Error);
    }
}
